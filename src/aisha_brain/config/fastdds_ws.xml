<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Fast DDS profile for the Workstation (WhatsApp relay / dev).
  Runs: whatsapp_listener (production) or all nodes (dev_mode)
  Device IP: 172.23.23.10  (edit to match your network)
  participantID: 2
  ROS_DOMAIN_ID: 42  (if changed, recalculate ports below)

  Multi-participant discovery: see fastdds_jetson.xml for explanation.
  For production, use scripts/generate_fastdds_configs.sh to regenerate.

  Usage:
    export FASTRTPS_DEFAULT_PROFILES_FILE=/path/to/fastdds_ws.xml
    ros2 launch aisha_integration ws_launch.py
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <profiles>
        <participant profile_name="aisha_ws" is_default_profile="true">
            <rtps>
                <participantID>2</participantID>

                <builtin>
                    <discovery_config>
                        <discoveryProtocol>SIMPLE</discoveryProtocol>

                        <simpleEDP>
                            <PUBWRITER_SUBREADER>true</PUBWRITER_SUBREADER>
                            <PUBREADER_SUBWRITER>true</PUBREADER_SUBWRITER>
                        </simpleEDP>
                        <leaseDuration>
                            <sec>20</sec>
                        </leaseDuration>
                        <initialAnnouncements>
                            <count>5</count>
                            <period>
                                <sec>1</sec>
                            </period>
                        </initialAnnouncements>
                    </discovery_config>

                    <metatrafficUnicastLocatorList>
                        <locator>
                            <udpv4>
                                <address>172.23.23.10</address>
                            </udpv4>
                        </locator>
                    </metatrafficUnicastLocatorList>

                    <initialPeersList>
                        <!-- Workstation  172.23.23.10  — 3 participants -->
                        <locator><udpv4><address>172.23.23.10</address><port>17910</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.10</address><port>17912</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.10</address><port>17914</port></udpv4></locator>
                        <!-- Jetson      172.23.23.20  — 10 participants -->
                        <locator><udpv4><address>172.23.23.20</address><port>17910</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17912</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17914</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17916</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17918</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17920</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17922</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17924</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17926</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.20</address><port>17928</port></udpv4></locator>
                        <!-- RPi 5       172.23.23.51  — 8 participants -->
                        <locator><udpv4><address>172.23.23.51</address><port>17910</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.51</address><port>17912</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.51</address><port>17914</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.51</address><port>17916</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.51</address><port>17918</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.51</address><port>17920</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.51</address><port>17922</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.51</address><port>17924</port></udpv4></locator>
                        <!-- RPi 4b      172.23.23.52  — 2 participants -->
                        <locator><udpv4><address>172.23.23.52</address><port>17910</port></udpv4></locator>
                        <locator><udpv4><address>172.23.23.52</address><port>17912</port></udpv4></locator>
                    </initialPeersList>
                </builtin>

                <defaultUnicastLocatorList>
                    <locator>
                        <udpv4>
                            <address>172.23.23.10</address>
                        </udpv4>
                    </locator>
                </defaultUnicastLocatorList>

                <sendSocketBufferSize>1048576</sendSocketBufferSize>
                <listenSocketBufferSize>4194304</listenSocketBufferSize>
                <useBuiltinTransports>true</useBuiltinTransports>
            </rtps>
        </participant>
    </profiles>
</dds>
