<?xml version="1.0"?>
<robot name="my_robot">

  <!-- Base Link -->
  <link name="base_link"/>

  <!-- LiDAR Link
       Frame name MUST be "laser" to match:
         - slam.launch.py static_transform_publisher (child-frame-id: laser)
         - robot_bringup/config/ld19.yaml (frame_id: laser)
         - ldlidar_stl_ros2 topic frame_id override in slam.launch.py
       Previously "base_laser", which caused a TF tree split when
       robot_state_publisher and slam.launch.py ran on the same device —
       RSP would publish base_link→base_laser while the static TF published
       base_link→laser, leaving slam_toolbox unable to resolve the scan frame.
  -->
  <link name="laser"/>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.0 0.0 0.2" rpy="0 0 0"/>
  </joint>

  <!-- Camera Link -->
  <link name="camera_link"/>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.15 0.0 0.25" rpy="0 0 0"/>
  </joint>

</robot>
