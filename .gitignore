# ROS 2 build artifacts
build/
install/
log/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Editor / OS
*.swp
*.bak
*.backup
*~

# Claude Code local tooling state (memory, settings)
.claude/

# Large / regenerable binaries (shipped or rebuilt separately)
*.pt
*.engine
*.onnx
*.pdf

# Generated knowledge base — rebuild via build_knowledge.py
**/aisha_knowledge_db/

# Vendored packages that carry their own git history
realsense-ros/
slam_toolbox/
web_video_server/
.colcon_install_layout
# IDE
.vscode/
.idea/
*.code-workspace
# OS
.DS_Store
Thumbs.db
# Secrets
.env
*.key
# Model files (too large for git)
*.bin
*.safetensors
*.whl
# Temp files
*.swo
# ROS2 bags
*.bag
*.db3

# Mediapipe Tasks API model bundles (fetch via scripts/fetch_mediapipe_task_models.sh)
models/

# ── Face-auth skill: NEVER commit biometric data or models ──────────────
# Runtime data lives outside the repo (default ~/face_auth), but guard the
# in-repo tree too in case anyone drops data next to the code.
tools/face_auth/gallery/
tools/face_auth/models/
tools/face_auth/**/*.onnx
tools/face_auth/**/*.zip
tools/face_auth/admins.json
tools/face_auth/session.json
tools/face_auth/__pycache__/
*.npz

# ── Video-messenger skill: NEVER commit recordings or credentials ───────
# Runtime data lives outside the repo (default ~/video_messages).
tools/video_messenger/outbox/
tools/video_messenger/sent/
tools/video_messenger/config.json
tools/video_messenger/__pycache__/
VM_*.mp4
