# ─── Network ────────────────────────────────────────────────────────────────
# IMPORTANT: These IPs MUST be statically assigned — either via DHCP
# reservations (MAC-to-IP bindings) at the router, or via static config
# on each device.  If DHCP assigns different addresses, FastDDS unicast
# discovery will fail and nodes will be invisible across devices.
JETSON_IP=172.23.23.20
RPI_IP=172.23.23.51
WS_IP=172.23.23.10
JETSON_USER=jetson

# ─── ROS2 / DDS ─────────────────────────────────────────────────────────────
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_DOMAIN_ID=0

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_ROUTER_MODEL=gemma3:270m
OLLAMA_LLM_MODEL=llama3.2
# VRAM tuning for 8 GB Jetson — lower these if you hit OOM
OLLAMA_GPU_LAYERS=999
OLLAMA_NUM_CTX=2048

# ─── Whisper STT ─────────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
AUDIO_CAPTURE_DEVICE=plughw:1,0

# ─── Piper TTS ───────────────────────────────────────────────────────────────
PIPER_VOICE_MODEL=en_US-amy-low.onnx
AUDIO_PLAYBACK_DEVICE=plughw:0,0

# ─── WhatsApp ────────────────────────────────────────────────────────────────
WA_ALLOWED_NUMBER=+971XXXXXXXXX

# ─── Paths on Jetson ─────────────────────────────────────────────────────────
JETSON_WS=/home/jetson/aisha_ws
JETSON_MODELS_DIR=/home/jetson/models
JETSON_KB_DIR=/home/jetson/aisha_knowledge_db
JETSON_PIPER_DIR=/home/jetson/piper
